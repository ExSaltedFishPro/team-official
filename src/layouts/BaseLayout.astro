---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

import type { SiteData } from "../types/content";

interface Props {
  site: SiteData;
}

const { site } = Astro.props;

const lang = site.seo.lang ?? "en";
const canonical = new URL(Astro.url.pathname, site.seo.siteUrl).toString();
const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.brand.name,
  url: site.seo.siteUrl,
  logo: new URL(site.brand.logo, site.seo.siteUrl).toString(),
  description: site.seo.description,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.seo.title}</title>
    <meta name="description" content={site.seo.description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={site.seo.favicon} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={site.seo.title} />
    <meta property="og:description" content={site.seo.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(site.seo.ogImage, site.seo.siteUrl).toString()} />
    <meta property="og:site_name" content={site.brand.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f4f5f7" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
  </head>
  <body>
    <SiteHeader
      brandName={site.brand.shortName ?? site.brand.name}
      logo={site.brand.logo}
      navigation={site.navigation}
    />
    <slot />
    <SiteFooter brandName={site.brand.name} footer={site.footer} />
    <script is:inline>
      const initChrome = () => {
        const header = document.querySelector("[data-site-header]");
        const links = Array.from(document.querySelectorAll("[data-anchor-link]"));
        const sections = Array.from(document.querySelectorAll("main section[id]"));
        const revealTargets = Array.from(document.querySelectorAll("[data-reveal]"));
        let ticking = false;

        const updateHeader = () => {
          if (header) {
            header.toggleAttribute("data-scrolled", window.scrollY > 24);
          }
        };

        const setActiveLink = (id) => {
          links.forEach((link) => {
            link.toggleAttribute("data-active", link.getAttribute("href") === `#${id}`);
          });
        };

        const updateActiveLink = () => {
          if (sections.length === 0 || links.length === 0) {
            return;
          }

          const headerHeight = header instanceof HTMLElement ? header.offsetHeight : 0;
          const anchorLine = window.scrollY + headerHeight + window.innerHeight * 0.18;

          let activeSection = sections[0];

          for (const section of sections) {
            if (section.offsetTop <= anchorLine) {
              activeSection = section;
            } else {
              break;
            }
          }

          const id = activeSection.getAttribute("id");
          if (id) {
            setActiveLink(id);
          }
        };

        const syncChrome = () => {
          updateHeader();
          updateActiveLink();
          ticking = false;
        };

        const requestSyncChrome = () => {
          if (ticking) {
            return;
          }

          ticking = true;
          window.requestAnimationFrame(syncChrome);
        };

        syncChrome();
        window.addEventListener("scroll", requestSyncChrome, { passive: true });
        window.addEventListener("resize", requestSyncChrome);
        window.addEventListener("hashchange", requestSyncChrome);

        if ("IntersectionObserver" in window) {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            {
              threshold: 0.16,
              rootMargin: "0px 0px -8% 0px",
            },
          );

          revealTargets.forEach((target) => revealObserver.observe(target));
        } else {
          revealTargets.forEach((target) => target.classList.add("is-visible"));
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initChrome, { once: true });
      } else {
        initChrome();
      }
    </script>
  </body>
</html>
